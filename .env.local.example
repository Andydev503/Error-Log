# Copy this file to `.env.local` and fill in the values.

# --- Supabase (Project Settings → API) ------------------------------------
# The project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# The "anon" / public key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google Gemini (free) — https://aistudio.google.com/apikey -------------
# Optional: leave blank to disable AI worked solutions. Server-side only.
GEMINI_API_KEY=
# Optional default model (users can also pick a model in the UI per request).
GEMINI_MODEL=gemini-3.5-flash

# --- Admin page (optional) -------------------------------------------------
# Comma-separated emails allowed to see the /admin page and manage accounts.
ADMIN_EMAILS=
# Supabase SECRET key (sb_secret_...) from Project Settings → API Keys.
# Server-only — required for the admin page to list/manage accounts. Never
# prefix this with NEXT_PUBLIC.
SUPABASE_SECRET_KEY=
