# Copy this file to `.env.local` and fill in the values.

# --- Supabase (Project Settings → API) ------------------------------------
# The project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# The "anon" / public key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google Gemini (free) — https://aistudio.google.com/apikey -------------
# Optional: leave blank to disable AI worked solutions. Server-side only.
GEMINI_API_KEY=
# Optional override; defaults to a free-tier vision model.
GEMINI_MODEL=gemini-2.5-flash
